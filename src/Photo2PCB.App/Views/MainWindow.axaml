<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Photo2PCB.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Photo2PCB.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding WindowTitle}"
        Width="800" Height="600"
        MinWidth="640" MinHeight="400"
        DragDrop.AllowDrop="True">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAsCommand}"/>
    </Window.KeyBindings>

    <DockPanel>
        <!-- File menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open…" Command="{Binding OpenCommand}" InputGesture="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGesture="Ctrl+S"
                          IsEnabled="{Binding HasImage}"/>
                <MenuItem Header="Save _As…" Command="{Binding SaveAsCommand}" InputGesture="Ctrl+Shift+S"
                          IsEnabled="{Binding HasImage}"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="10,5"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ProgressBar IsIndeterminate="True" Width="80" Height="4"
                             IsVisible="{Binding IsBusy}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <!-- Main: preview (2/3) + controls (1/3) -->
        <Grid ColumnDefinitions="2*,Auto,1*">
            <!-- Preview: neutral panel with a white 'paper' card so the SVG output reads
                 regardless of light/dark theme. Accepts drag-and-drop of an image. -->
            <Border Grid.Column="0" Margin="8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                <Panel>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="6" IsVisible="{Binding !HasImage}">
                        <TextBlock Text="No image loaded" TextAlignment="Center"
                                   FontSize="15" Opacity="0.7"/>
                        <TextBlock Text="File › Open, or drag a PNG / JPG here"
                                   TextAlignment="Center" Opacity="0.5"/>
                    </StackPanel>

                    <Border IsVisible="{Binding HasImage}" Margin="16"
                            Background="White" BorderThickness="1" CornerRadius="2"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BoxShadow="0 2 12 0 #40000000"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="4"/>
                    </Border>

                    <!-- Physical-size readout overlaid on the preview -->
                    <Border IsVisible="{Binding HasImage}"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="10" Padding="8,4" CornerRadius="4"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                            Opacity="0.92">
                        <TextBlock Text="{Binding PhysicalSize}" FontFamily="Consolas,Menlo,monospace"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </Panel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"
                          Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

            <!-- Controls -->
            <DockPanel Grid.Column="2" Margin="12,8,8,8">
                <!-- Action buttons pinned bottom-right -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
                    <Button Content="Save As…" Command="{Binding SaveAsCommand}"
                            IsEnabled="{Binding HasImage}" Classes="accent"/>
                    <Button Content="Cancel" Command="{Binding ExitCommand}"/>
                </StackPanel>

                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Settings" FontWeight="Bold" FontSize="16"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Reset" Command="{Binding ResetDefaultsCommand}"
                                Padding="10,2" FontSize="12"/>
                    </Grid>

                    <!-- Contrast -->
                    <StackPanel Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Contrast"/>
                            <TextBlock Grid.Column="1" Text="{Binding ContrastPercent, StringFormat='{}{0:0}%'}"
                                       FontWeight="SemiBold"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="100" Value="{Binding ContrastPercent}"
                                TickFrequency="25" TickPlacement="BottomRight"/>
                    </StackPanel>

                    <!-- Brightness -->
                    <StackPanel Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Brightness"/>
                            <TextBlock Grid.Column="1" Text="{Binding BrightnessPercent, StringFormat='{}{0:0}%'}"
                                       FontWeight="SemiBold"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="100" Value="{Binding BrightnessPercent}"
                                TickFrequency="25" TickPlacement="BottomRight"/>
                        <TextBlock Text="0 = dark · 100 = white" FontSize="11" Opacity="0.6"/>
                    </StackPanel>

                    <!-- Background cutoff -->
                    <StackPanel Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Background cutoff"/>
                            <TextBlock Grid.Column="1" Text="{Binding BackgroundCutoffPercent, StringFormat='{}{0:0}%'}"
                                       FontWeight="SemiBold"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="100" Value="{Binding BackgroundCutoffPercent}"/>
                        <TextBlock Text="Drop strokes lighter than this (higher = whiter background)"
                                   FontSize="11" Opacity="0.6"/>
                    </StackPanel>

                    <!-- Min aperture (light strokes) -->
                    <StackPanel Spacing="3">
                        <TextBlock Text="{Binding MinApertureLabel}"/>
                        <Slider Minimum="{Binding ApertureLimitMinMm}" Maximum="{Binding ApertureLimitMaxMm}"
                                Value="{Binding MinApertureMm}" SmallChange="0.0254" LargeChange="0.127"/>
                    </StackPanel>

                    <!-- Max aperture (dark strokes) -->
                    <StackPanel Spacing="3">
                        <TextBlock Text="{Binding MaxApertureLabel}"/>
                        <Slider Minimum="{Binding ApertureLimitMinMm}" Maximum="{Binding ApertureLimitMaxMm}"
                                Value="{Binding MaxApertureMm}" SmallChange="0.0254" LargeChange="0.127"/>
                        <TextBlock Text="Light→thin, dark→thick traces · 0.127 mm (5 mil) – 1.27 mm (50 mil)"
                                   FontSize="11" Opacity="0.6"/>
                    </StackPanel>

                    <!-- Image height -->
                    <StackPanel Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Image height"/>
                            <TextBlock Grid.Column="1" Text="{Binding HeightMm, StringFormat='{}{0:0.#} mm'}"
                                       FontWeight="SemiBold"/>
                        </Grid>
                        <Slider Minimum="{Binding MinHeightMm}" Maximum="{Binding MaxHeightMm}"
                                Value="{Binding HeightMm}" SmallChange="1" LargeChange="10"/>
                        <TextBlock Text="Overall height; width follows the photo's aspect ratio"
                                   FontSize="11" Opacity="0.6"/>
                    </StackPanel>

                    <!-- Line count -->
                    <StackPanel Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Line count"/>
                            <TextBlock Grid.Column="1" Text="{Binding LineCount, StringFormat='{}{0} lines'}"
                                       FontWeight="SemiBold"/>
                        </Grid>
                        <Slider Minimum="{Binding MinLineCount}" Maximum="{Binding MaxLineCount}"
                                Value="{Binding LineCount}" SmallChange="1" LargeChange="10"
                                TickFrequency="1" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding SpacingLabel}" FontSize="11" Opacity="0.75"/>
                        <TextBlock Text="{Binding MaxLineCount, StringFormat='Max {0} lines at this height + aperture'}"
                                   FontSize="11" Opacity="0.6"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
