<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Photo2PCB.App.App"
             RequestedThemeVariant="Default">
    <!-- RequestedThemeVariant="Default" follows the host OS light/dark setting. -->
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
